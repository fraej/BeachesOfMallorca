{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start Web Server",
            "type": "shell",
            "command": "npx",
            "args": ["-y", "http-server", ".", "-p", "8080", "-c-1", "--cors"],
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "Starting up http-server",
                    "endsPattern": "Hit CTRL-C to stop the server"
                }
            },
            "presentation": {
                "reveal": "silent",
                "panel": "dedicated"
            }
        }
    ]
}
